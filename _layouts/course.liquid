---
layout: page
---
<div class="course">
  {% if page.audience or page.course_type or page.teaching_format %}
    <div class="course-info">
      {% if page.audience %}
        <p><strong>Audience:</strong> {{ page.audience }}</p>
      {% endif %}
      {% if page.course_type %}
        <p><strong>Course Type:</strong> {{ page.course_type }}</p>
      {% endif %}
      {% if page.teaching_format %}
        <p><strong>Format:</strong> {{ page.teaching_format }}</p>
      {% endif %}
    </div>
  {% endif %}

  {% if page.topics %}
    <div class="course-topic-list course-topic-list-page">
      {% for topic in page.topics %}
        <span class="course-topic">{{ topic }}</span>
      {% endfor %}
    </div>
  {% endif %}

  {% if page.modules %}
    <div class="course-module-grid">
      {% for module in page.modules %}
        <section class="course-module">
          <h2>{{ module.title }}</h2>
          {% if module.description %}
            <p>{{ module.description }}</p>
          {% endif %}
          {% if module.topics %}
            <ul class="course-module-list">
              {% for topic in module.topics %}
                <li>{{ topic }}</li>
              {% endfor %}
            </ul>
          {% endif %}
        </section>
      {% endfor %}
    </div>
  {% endif %}

  {{ content }}
</div>
